# Copia a `.env.production` en el VPS o CI (no versionar). Valores públicos de referencia.
# `npm run build` usa estas variables en tiempo de build; si faltan, `runtime-config.js`
# aplica fallbacks en producción para la API (https://api.frigest.es).

VITE_APP_BACKEND_PROVIDER=rest
VITE_APP_API_URL=https://api.frigest.es
# Login principal: SPA en app.frigest.es; estas URLs siguen siendo válidas para compatibilidad/legacy.
VITE_APP_LOGIN_URL=https://api.frigest.es/api/auth/login
VITE_APP_LOGOUT_URL=https://api.frigest.es/api/auth/logout-page
# Opcional: debe coincidir con APP_ID del servidor (no es secreto; conviene alinear build y API).
# VITE_APP_ID=
